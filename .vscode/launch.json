{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🛡️ Run Dashboard (Demo)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "args": ["--demo", "--port", "5050"],
            "python": "${workspaceFolder}/venv/bin/python",
            "console": "integratedTerminal"
        },
        {
            "name": "🧠 Train Models (Multi)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "args": ["--mode", "multi"],
            "python": "${workspaceFolder}/venv/bin/python",
            "console": "integratedTerminal"
        }
    ]
}
